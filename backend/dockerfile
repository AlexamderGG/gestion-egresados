# backend/Dockerfile
FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN ls -la                    # Ver qué archivos hay
RUN npm run build || cat     # Mostrar error si falla
RUN ls -la dist              # Verificar que dist se creó

FROM node:20-alpine
WORKDIR /app
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/node_modules ./node_modules
COPY package*.json ./
RUN ls -la                    # Verificar que dist está presente
EXPOSE 4000
CMD ["node", "dist/main.js"]